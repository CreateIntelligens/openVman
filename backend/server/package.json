{
  "name": "@openvman/backend-server",
  "version": "0.1.0",
  "description": "Main Backend (Nervous System) for openVman",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "npm run build && node --test dist/*.test.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "fastify": "^4.24.3",
    "@fastify/cors": "^8.4.1",
    "ws": "^8.14.2",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
