# ==========================================
# openVman Backend Gateway — Environment Variables
# ==========================================

# === Gateway Server ===
GATEWAY_PORT=8050
NODE_ENV=development

# === Redis (BullMQ) ===
REDIS_URL=redis://localhost:6379

# === Temp Storage ===
GATEWAY_TEMP_DIR=/tmp/vman-gateway
GATEWAY_TEMP_TTL_MIN=30
GATEWAY_TEMP_DIR_MAX_MB=2048
GATEWAY_MAX_FILE_SIZE_MB=100

# === Media Processing ===
MEDIA_PROCESSING_TIMEOUT_MS=5000
# Supported MIME types (comma-separated)
MEDIA_SUPPORTED_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime,audio/mpeg,audio/wav,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# === Vision LLM (for image/video frame descriptions) ===
VISION_LLM_PROVIDER=openai          # openai | local-llava
VISION_LLM_API_KEY=sk-***
VISION_LLM_MODEL=gpt-4o
VISION_LLM_BASE_URL=                # Leave empty for OpenAI default; set for local LLaVA

# === Audio Transcription (Whisper) ===
WHISPER_PROVIDER=openai             # openai | local
WHISPER_API_KEY=sk-***
WHISPER_LOCAL_BIN=/usr/local/bin/whisper

# === MarkItDown (Document Parser) ===
MARKITDOWN_URL=http://localhost:8200  # HTTP service wrapping MarkItDown

# === Camera Live Plugin ===
CAMERA_SNAPSHOT_INTERVAL_SEC=5      # Valid range: 2–60

# === API Tool Plugin ===
API_TOOL_TIMEOUT_MS=10000
API_TOOL_MAX_QUEUE=10
API_REGISTRY_PATH=./config/api-registry.yaml

# === Web Crawler Plugin ===
CRAWLER_TIMEOUT_MS=15000
CRAWLER_CACHE_TTL_MIN=60
CRAWLER_IGNORE_ROBOTS=false
# Comma-separated blocked domains
CRAWLER_BLOCKED_DOMAINS=

# === Backend (internal enrich endpoint) ===
BACKEND_INTERNAL_URL=http://localhost:8080

# === Task Queue ===
QUEUE_JOB_TIMEOUT_MS=30000

# === Prometheus Metrics ===
METRICS_ENABLED=true
METRICS_PORT=9090

# === Logging ===
LOG_LEVEL=info                      # trace | debug | info | warn | error
