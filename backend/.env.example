# ─── Backend Server ───
BACKEND_SERVER_PORT=8080
BACKEND_SERVER_HOST=0.0.0.0
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Index TTS (High Priority) ───
TTS_INDEX_URL=http://10.9.0.35:8001
TTS_INDEX_CHARACTER=hayley

# ─── TTS Worker (Primary) ───
TTS_PRIMARY_VOICE=zh-TW-HsiaoChenNeural
TTS_PRIMARY_SAMPLE_RATE=24000
TTS_PRIMARY_MAX_TEXT_LENGTH=2000
TTS_PRIMARY_PORT=9001

# ─── TTS Worker (Secondary) ───
TTS_SECONDARY_VOICE=zh-TW-YunJheNeural
TTS_SECONDARY_SAMPLE_RATE=24000
TTS_SECONDARY_MAX_TEXT_LENGTH=2000
TTS_SECONDARY_PORT=9002

# ─── Backend (TTS + Gateway) ───
BACKEND_PORT=8200
UVICORN_RELOAD=1
MARKITDOWN_MAX_UPLOAD_BYTES=10485760

# ─── Gateway ───
REDIS_URL=redis://redis:6379
GATEWAY_TEMP_DIR=/tmp/vman-gateway
GATEWAY_TEMP_TTL_MIN=30
GATEWAY_TEMP_DIR_MAX_MB=2048
GATEWAY_MAX_FILE_SIZE_MB=100
MEDIA_PROCESSING_TIMEOUT_MS=5000
QUEUE_JOB_TIMEOUT_MS=30000

# ─── Node Health Policy ───
NODE_FAILURE_THRESHOLD=2
NODE_COOLDOWN_SECONDS=30
NODE_SCORE_PENALTY=50
NODE_TIMEOUT_MS=10000

# ─── AWS Polly (optional) ───
TTS_AWS_ENABLED=false
TTS_AWS_REGION=ap-northeast-1
TTS_AWS_ACCESS_KEY_ID=
TTS_AWS_SECRET_ACCESS_KEY=
TTS_AWS_POLLY_VOICE_ID=Zhiyu
TTS_AWS_POLLY_ENGINE=neural
TTS_AWS_OUTPUT_FORMAT=pcm
TTS_AWS_SAMPLE_RATE=24000

# ─── GCP Cloud TTS (optional) ───
TTS_GCP_ENABLED=false
TTS_GCP_PROJECT_ID=
TTS_GCP_CREDENTIALS_JSON=
TTS_GCP_VOICE_NAME=cmn-TW-Standard-A
TTS_GCP_AUDIO_ENCODING=LINEAR16
TTS_GCP_SAMPLE_RATE=24000

# ─── Vision LLM ───
VISION_LLM_API_KEY=
VISION_LLM_MODEL=gpt-4o
VISION_LLM_BASE_URL=

# ─── Whisper (audio transcription) ───
WHISPER_PROVIDER=openai
WHISPER_API_KEY=
WHISPER_LOCAL_BIN=/usr/local/bin/whisper

# ─── Camera ───
CAMERA_SNAPSHOT_INTERVAL_SEC=5

# ─── API Tool ───
API_TOOL_TIMEOUT_MS=10000
API_TOOL_MAX_QUEUE=10
API_REGISTRY_PATH=./config/api-registry.yaml

# ─── Web Crawler ───
CRAWLER_TIMEOUT_MS=15000
CRAWLER_CACHE_TTL_MIN=60
CRAWLER_IGNORE_ROBOTS=false
CRAWLER_BLOCKED_DOMAINS=

# ─── Internal ───
BRAIN_URL=http://brain:8100
