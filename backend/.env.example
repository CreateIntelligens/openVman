# ─── Backend ───
ENV=dev                                    # dev | prod
# BACKEND_PORT=8200                       # 預設 8200

# ─── IndexTTS (primary) ───
# TTS_INDEXTTS_URL=                       # 由 docker-compose 注入
TTS_INDEXTTS_DEFAULT_CHARACTER=hayley      # 預設語音角色

# ─── VibeVoice (封存) ───
# TTS_VIBEVOICE_URL=http://vibevoice-serve:3000

# ─── Edge-TTS (fallback, in-process) ───
# TTS_EDGE_ENABLED=true                   # 預設 true
# TTS_EDGE_VOICE=zh-TW-HsiaoChenNeural
# TTS_EDGE_SAMPLE_RATE=24000
# TTS_EDGE_MAX_TEXT_LENGTH=2000

# ─── AWS Polly (optional) ───
# TTS_AWS_ENABLED=false
# TTS_AWS_REGION=ap-northeast-1
# TTS_AWS_ACCESS_KEY_ID=
# TTS_AWS_SECRET_ACCESS_KEY=

# ─── GCP Cloud TTS (optional) ───
# TTS_GCP_ENABLED=false
# TTS_GCP_PROJECT_ID=
# TTS_GCP_CREDENTIALS_JSON=

# ─── Gateway ───
# MARKITDOWN_MAX_UPLOAD_BYTES=10485760
CRAWLER_PROVIDER_URL=

# ─── Vision LLM ───
# VISION_LLM_API_KEY=
# VISION_LLM_MODEL=gpt-4o

# ─── Whisper ───
# WHISPER_PROVIDER=openai
# WHISPER_API_KEY=
