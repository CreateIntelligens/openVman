# 對外統一入口 port
PORT=8786
HTTPS_PORT=8787

# HuggingFace token (for private model repos)
HF_TOKEN=

# Optional local VLM eyes service (`docker compose --profile vlm up -d vlm`)
VLM_IMAGE=vllm/vllm-openai:v0.11.0
VLM_MODEL=Qwen/Qwen3-VL-4B-Instruct-FP8
VLM_SERVED_MODEL=openvman-vlm
VLM_MAX_MODEL_LEN=1024
VLM_MAX_NUM_SEQS=1
VLM_MAX_NUM_BATCHED_TOKENS=512
VLM_GPU_MEMORY_UTILIZATION=0.3
