# ============================================================================
# Brain .env 設定檔
# 複製此檔為 .env 並填入必要值即可啟動
# [required] = 必填，沒填會影響功能
# [optional] = 選填，有合理預設值
#
# 進階 tuning 參數（prompt budget、chunk、RAG、memory decay、agent 等）
# 請參考 api/config.py 的 BrainSettings class，所有欄位皆可透過同名
# 大寫環境變數覆蓋，這裡只列出部署時常用的設定。
# ============================================================================

# === 環境 ===
ENV=dev                                # [optional] dev | prod

# === 大腦層設定 ===
PORT=8787                              # [optional] API 對外 port

# === LLM 設定 ===
LLM_PROVIDER=gemini                    # [required] openai | gemini | azure | claude | vllm | groq
LLM_MODEL=gemini-3.1-flash-lite-preview # [required] 主要使用的模型
LLM_BASE_URL=                          # [optional] 自訂 LLM base URL（留空則依 provider 自動帶入預設值）
LLM_TEMPERATURE=0.3                    # [optional] LLM 生成溫度

# === Provider API Keys（填對應 LLM_PROVIDER 的那一個即可）===
GEMINI_API_KEY=                        # [required if provider=gemini] Google Gemini
GROQ_API_KEY=                          # [required if provider=groq]   Groq (Llama, Mixtral)
OPENAI_API_KEY=                        # [required if provider=openai] OpenAI (GPT-4o, GPT-4o-mini)

# === Embedding 設定 ===
EMBEDDING_MODEL=BAAI/bge-m3            # [optional] embedding 模型名稱
EMBEDDING_USE_FP16=true                # [optional] 是否使用 FP16 加速
EMBEDDING_DEVICE=cuda                  # [optional] cuda | cpu

# === 記憶設定 ===
SHORT_TERM_MEMORY_ROUNDS=20            # [optional] 短期記憶保留輪數
RAG_TOP_K=5                            # [optional] RAG 檢索 top-k
MAX_SESSION_ROUNDS=100                 # [optional] 單 session 最大輪數
MAX_SESSION_TTL_MINUTES=30             # [optional] session 存活時間（分鐘）

# === 安全設定 ===
MAX_INPUT_LENGTH=500                   # [optional] 使用者輸入最大字元數
ENABLE_CONTENT_FILTER=true             # [optional] 啟用內容過濾
REQUEST_RATE_LIMIT_PER_MINUTE=90       # [optional] 每分鐘請求上限
ALLOWED_CHANNELS=web,api,kiosk,admin,system # [optional] 允許的 channel 列表
