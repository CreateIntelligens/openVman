# ============================================================================
# Brain .env 設定檔
# 複製此檔為 .env 並填入必要值即可啟動
# [required] = 必填，沒填會影響功能
# [optional] = 選填，有合理預設值
#
# 進階 tuning 參數（prompt budget、chunk、RAG、memory decay、agent 等）
# 請參考 api/config.py 的 BrainSettings class，所有欄位皆可透過同名
# 大寫環境變數覆蓋，這裡只列出部署時常用的設定。
# ============================================================================

# === 環境 ===
ENV=dev                                # [optional] dev | prod

# === 大腦層設定 ===
PORT=8787                              # [optional] API 對外 port

# === LLM 設定 ===
LLM_PROVIDER=gemini                    # [required] openai | gemini | azure | claude | vllm | groq
LLM_MODEL=gemini-3.1-flash-lite-preview # [required] 主要使用的模型
LLM_BASE_URL=                          # [optional] 自訂 LLM base URL（留空則依 provider 自動帶入預設值）
LLM_TEMPERATURE=0.3                    # [optional] LLM 生成溫度

# === Gemini Live（由 Brain 持有 session / tools / RAG，共用 GEMINI_API_KEY）===
LIVE_GEMINI_MODEL=gemini-3.1-flash-live-preview # [optional] Gemini Live model
LIVE_GEMINI_SYSTEM_INSTRUCTION=        # [optional] Live session system instruction
LIVE_GEMINI_OUTPUT_AUDIO_TRANSCRIPTION=true # [optional] 是否要求音訊輸出轉錄
LIVE_GEMINI_TOOLS_ENABLED=true         # [optional] 是否開啟 Brain 內部 tool calling
LIVE_GEMINI_THINKING_LEVEL=            # [optional] 依 provider 支援情況設定

# === Provider API Keys（填對應 LLM_PROVIDER 的那一個即可）===
GEMINI_API_KEY=                        # [required if provider=gemini] Google Gemini
GROQ_API_KEY=                          # [required if provider=groq]   Groq (Llama, Mixtral)
OPENAI_API_KEY=                        # [required if provider=openai] OpenAI (GPT-4o, GPT-4o-mini)
VOYAGE_API_KEY=                        # [required if embedding provider=voyage] Voyage AI

# === Embedding 設定 ===
EMBEDDING_ACTIVE_VERSION=bge           # [optional] 目前啟用的 embedding version: bge | gemini | openai | voyage
EMBEDDING_VERSION_ORDER=bge,gemini,openai,voyage # [optional] embedding 版本順序（不混用同一個向量空間）
EMBEDDING_MODEL=BAAI/bge-m3            # [optional] bge 版本使用的本地模型
EMBEDDING_USE_FP16=true                # [optional] bge 是否使用 FP16 加速
EMBEDDING_DEVICE=cuda                  # [optional] bge: cuda | cpu
EMBEDDING_GEMINI_MODEL=gemini-embedding-001 # [optional] Gemini embedding model
EMBEDDING_GEMINI_DIMENSIONS=0          # [optional] 0 代表使用 provider 預設維度
EMBEDDING_OPENAI_MODEL=text-embedding-3-small # [optional] OpenAI embedding model
EMBEDDING_OPENAI_DIMENSIONS=0          # [optional] 0 代表使用 provider 預設維度
EMBEDDING_VOYAGE_MODEL=voyage-3-large  # [optional] Voyage embedding model
EMBEDDING_VOYAGE_DIMENSIONS=0          # [optional] 0 代表使用 provider 預設維度

# === 記憶設定 ===
SHORT_TERM_MEMORY_ROUNDS=20            # [optional] 短期記憶保留輪數
RAG_TOP_K=5                            # [optional] RAG 檢索 top-k
MAX_SESSION_ROUNDS=100                 # [optional] 單 session 最大輪數
MAX_SESSION_TTL_MINUTES=43200          # [optional] session 存活時間（分鐘，30 天）

# === Dreaming 設定 ===
DREAMING_ENABLED=false                # [optional] 是否啟用背景記憶整合
DREAMING_CRON="0 3 * * *"             # [optional] 排程 cron（預設每天 03:00）
DREAMING_TIMEZONE=Asia/Taipei          # [optional] 排程時區
DREAMING_LOOKBACK_DAYS=7               # [optional] Light/REM phase 回看天數
DREAMING_MIN_SCORE=0.45                # [optional] Deep phase promote 最低分數
DREAMING_MIN_RECALL_COUNT=2            # [optional] Deep phase 最低 recall 次數
DREAMING_CANDIDATE_LIMIT=100           # [optional] Light phase 候選上限
DREAMING_SIMILARITY_THRESHOLD=0.90     # [optional] 與既有 memories 去重門檻
DREAMING_PROJECTS=["default"]          # [optional] JSON array，排程要跑的 project_id 清單

# === 安全設定 ===
MAX_INPUT_LENGTH=500                   # [optional] 使用者輸入最大字元數
ENABLE_CONTENT_FILTER=true             # [optional] 啟用內容過濾
REQUEST_RATE_LIMIT_PER_MINUTE=90       # [optional] 每分鐘請求上限
ALLOWED_CHANNELS=web,api,kiosk,admin,system # [optional] 允許的 channel 列表
