# === 環境 ===
ENV=dev                                # dev | prod

# === 大腦層設定 ===
BRAIN_PORT=8787

# === LLM 設定 ===
BRAIN_LLM_PROVIDER=gemini           # openai | gemini | azure | claude | vllm
BRAIN_LLM_API_KEY=                  # 填入你的 Gemini API Key
BRAIN_LLM_API_KEYS=                 # 多 key pool，逗號分隔
BRAIN_LLM_MODEL=gemini-2.0-flash    # gemini-2.0-flash | gemini-1.5-pro
BRAIN_LLM_FALLBACK_MODEL=           # 主模型失敗時的備援模型
BRAIN_LLM_KEY_COOLDOWN_SECONDS=60
PROMPT_SYSTEM_CHAR_BUDGET=6000
PROMPT_CONTEXT_CHAR_BUDGET=2800
PROMPT_HISTORY_CHAR_BUDGET=2200
PROMPT_HISTORY_SUMMARY_CHAR_BUDGET=900

# === Embedding 設定 ===
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_USE_FP16=true
EMBEDDING_DEVICE=cuda               # cuda | cpu
LANCEDB_PATH=~/.openclaw/lancedb
KNOWLEDGE_INDEX_STATE_PATH=/data/knowledge_index_state.json

# === 記憶設定 ===
SHORT_TERM_MEMORY_ROUNDS=20
RAG_TOP_K=5
MAX_SESSION_ROUNDS=100
MAX_SESSION_TTL_MINUTES=30
SESSION_DB_PATH=/data/sessions.db
MEMORY_MAINTENANCE_INTERVAL_SECONDS=300

# === Agent 設定 ===
AGENT_LOOP_MAX_ROUNDS=6
TOOL_DOCUMENT_CHAR_LIMIT=4000

# === 安全設定 ===
MAX_INPUT_LENGTH=500
ENABLE_CONTENT_FILTER=true
