# ============================================================================
# Brain .env 設定檔
# 複製此檔為 .env 並填入必要值即可啟動
# [required] = 必填，沒填會影響功能
# [optional] = 選填，有合理預設值
#
# 進階 tuning 參數（prompt budget、chunk、RAG、memory decay、agent、
# Gemini Live、Dreaming、安全設定等）請參考 api/config.py 的
# BrainSettings class，所有欄位皆可透過同名大寫環境變數覆蓋，
# 這裡只列出部署時常用的設定。
# ============================================================================

# === 環境 ===
ENV=dev                                # [optional] dev | prod

# === 大腦層設定 ===
PORT=8787                              # [optional] API 對外 port

# === LLM 設定 ===
LLM_PROVIDER=gemini                    # [required] openai | gemini | azure | claude | vllm | groq
LLM_MODEL=gemini-3.1-flash-lite-preview # [required] 主要使用的模型

# === Provider API Keys（填對應 LLM_PROVIDER 的那一個即可）===
GEMINI_API_KEY=                        # [required if provider=gemini] Google Gemini
GROQ_API_KEY=                          # [required if provider=groq]   Groq (Llama, Mixtral)
OPENAI_API_KEY=                        # [required if provider=openai] OpenAI (GPT-4o, GPT-4o-mini)
VOYAGE_API_KEY=                        # [required if embedding=voyage] Voyage AI

# === Embedding 設定 ===
EMBEDDING_ACTIVE_VERSION=bge           # [optional] bge | gemini | openai | voyage

# === Dreaming 設定 ===
DREAMING_ENABLED=false                 # [optional] 是否啟用背景記憶整合

# === Privacy Filter 設定 ===
PRIVACY_FILTER_EGRESS_ENABLED=true     # [optional] true | false — 是否掃描 LLM 回應（egress）
PRIVACY_FILTER_DEVICE=cpu              # [optional] cpu | cuda — OPF 模型運算裝置
