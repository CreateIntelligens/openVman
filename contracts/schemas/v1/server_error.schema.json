{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openvman://protocol/v1/server_error",
  "title": "Server Error Event",
  "type": "object",
  "additionalProperties": false,
  "x-direction": "server_to_client",
  "x-contract-version": "1.0.0",
  "properties": {
    "event": {
      "const": "server_error"
    },
    "error_code": {
      "type": "string",
      "enum": [
        "TTS_TIMEOUT",
        "GATEWAY_TIMEOUT",
        "UPLOAD_FAILED",
        "LLM_OVERLOAD",
        "BRAIN_UNAVAILABLE",
        "AUTH_FAILED",
        "SESSION_EXPIRED",
        "INTERNAL_ERROR"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "retry_after_ms": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "event",
    "error_code",
    "message",
    "timestamp"
  ]
}
