{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openvman://protocol/v1/client_interrupt",
  "title": "Client Interrupt Event",
  "type": "object",
  "additionalProperties": false,
  "x-direction": "client_to_server",
  "x-contract-version": "1.0.0",
  "properties": {
    "event": {
      "const": "client_interrupt"
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    },
    "partial_asr": {
      "type": "string",
      "description": "Interim transcript text that triggered the interruption."
    }
  },
  "required": [
    "event",
    "timestamp"
  ]
}
