{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openvman://protocol/v1/server_init_ack",
  "title": "Server Init Ack Event",
  "type": "object",
  "additionalProperties": false,
  "x-direction": "server_to_client",
  "x-contract-version": "1.0.0",
  "properties": {
    "event": {
      "const": "server_init_ack"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "server_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": ["ok", "version_mismatch"]
    },
    "message": {
      "type": "string"
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "event",
    "session_id",
    "server_version",
    "status",
    "timestamp"
  ]
}
