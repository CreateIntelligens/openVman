{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openvman://protocol/v1/client_audio_chunk",
  "title": "Client Audio Chunk Event",
  "type": "object",
  "additionalProperties": false,
  "x-direction": "client_to_server",
  "x-contract-version": "1.0.0",
  "properties": {
    "event": {
      "const": "client_audio_chunk"
    },
    "audio_base64": {
      "type": "string",
      "minLength": 1
    },
    "sample_rate": {
      "type": "integer",
      "minimum": 1
    },
    "mime_type": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "event",
    "audio_base64",
    "sample_rate",
    "mime_type",
    "timestamp"
  ]
}
